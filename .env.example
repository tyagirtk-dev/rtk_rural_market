# Copy this file to .env and fill in real values. Never commit the real .env file.

# --- Core ---
SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=production
DATABASE_URL=sqlite:///database/rtk_rural_market.db

# --- Admin (fixed admin login, created automatically on first run) ---
ADMIN_MOBILE=9999999999
ADMIN_EMAIL=admin@rtkruralmarket.com
ADMIN_PASSWORD=change-this-admin-password

# --- SMTP (used for welcome mail, order updates, password-change notices, contact form) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=RTK Rural Market
SMTP_FROM_EMAIL=your-email@gmail.com
CONTACT_FORM_RECEIVER=your-email@gmail.com

# --- SMS OTP provider ---
# This app ships with an SMS gateway abstraction (services/sms_service.py) that logs
# OTPs to logs/otp.log and the console instead of sending real texts, because no SMS
# account/API key was provided. To go live, sign up with a provider (e.g. Twilio, MSG91,
# Fast2SMS) and fill these in, then flip SMS_PROVIDER to "twilio" or "msg91" and
# implement the matching branch in services/sms_service.py (clearly marked with TODOs).
SMS_PROVIDER=console
SMS_API_KEY=
SMS_API_SECRET=
SMS_SENDER_ID=RTKRML

# --- App ---
BASE_URL=http://127.0.0.1:5000
DELIVERY_CHARGE=40
FREE_DELIVERY_THRESHOLD=500
OTP_EXPIRY_MINUTES=5
